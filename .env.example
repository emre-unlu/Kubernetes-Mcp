# Kubernetes
K8S_NAMESPACE=default
KUBECONFIG_PATH=
K8S_CONTEXT=
K8S_IN_CLUSTER=false

# Prometheus
PROMETHEUS_URL=

# Jaeger
JAEGER_URL=

# Neo4j
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Timeouts
HTTP_TIMEOUT_SECONDS=15
SHELL_TIMEOUT_SECONDS=20

# MCP server
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000